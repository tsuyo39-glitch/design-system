{
  "$description": "Technical Minimalism — design tokens for the design-system builder app. DTCG format. Three layers: primitive (color/dimension/...), semantic (role-based, mode-aware via $extensions), component. Reference other tokens with {group.token}. Dark-mode values live in $extensions[\"com.tokens.mode\"].dark; the top-level $value is the light-mode value.",

  "color": {
    "$type": "color",
    "$description": "Primitive palette. Raw values with no meaning attached. Never consume these directly in UI — go through the semantic layer.",
    "neutral": {
      "0":   { "$value": "#FFFFFF" },
      "50":  { "$value": "#F7F8FA" },
      "100": { "$value": "#EDEFF3" },
      "200": { "$value": "#DDE1E8" },
      "300": { "$value": "#C3C9D4" },
      "400": { "$value": "#9AA2B1" },
      "500": { "$value": "#6B7280" },
      "600": { "$value": "#4B5261" },
      "700": { "$value": "#363C49" },
      "800": { "$value": "#232833" },
      "900": { "$value": "#171A21" },
      "950": { "$value": "#0E1015" }
    },
    "indigo": {
      "$description": "The single accent hue. If you re-theme, this is the one ramp to swap.",
      "50":  { "$value": "#EEF0FE" },
      "100": { "$value": "#E0E3FC" },
      "400": { "$value": "#818CF8" },
      "500": { "$value": "#6366F1" },
      "600": { "$value": "#4F46E5" }
    },
    "green":  { "400": { "$value": "#4ADE80" }, "500": { "$value": "#22C55E" }, "600": { "$value": "#16A34A" } },
    "amber":  { "400": { "$value": "#FBBF24" }, "500": { "$value": "#F59E0B" }, "600": { "$value": "#D97706" } },
    "red":    { "400": { "$value": "#F87171" }, "500": { "$value": "#EF4444" }, "600": { "$value": "#DC2626" } },
    "blue":   { "400": { "$value": "#60A5FA" }, "500": { "$value": "#3B82F6" }, "600": { "$value": "#2563EB" } }
  },

  "spacing": {
    "$type": "dimension",
    "$description": "4px base scale. Use these for margin, padding, and gap. Consistency here is the single biggest driver of a coherent look.",
    "0":  { "$value": "0px" },
    "1":  { "$value": "4px" },
    "2":  { "$value": "8px" },
    "3":  { "$value": "12px" },
    "4":  { "$value": "16px" },
    "5":  { "$value": "20px" },
    "6":  { "$value": "24px" },
    "8":  { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" }
  },

  "radius": {
    "$type": "dimension",
    "sm":   { "$value": "4px" },
    "md":   { "$value": "6px", "$description": "Default corner for controls." },
    "lg":   { "$value": "8px" },
    "xl":   { "$value": "12px", "$description": "Cards and panels." },
    "full": { "$value": "9999px" }
  },

  "borderWidth": {
    "$type": "dimension",
    "thin":  { "$value": "1px" },
    "thick": { "$value": "2px", "$description": "Focus ring only." }
  },

  "fontFamily": {
    "$type": "fontFamily",
    "sans": { "$value": ["Inter", "system-ui", "-apple-system", "Segoe UI", "sans-serif"], "$description": "All UI text." },
    "mono": { "$value": ["JetBrains Mono", "ui-monospace", "SFMono-Regular", "Menlo", "monospace"], "$description": "Every numeric value, hex code, token name, and code snippet. This is the signature of the system." }
  },

  "fontSize": {
    "$type": "dimension",
    "xs":  { "$value": "12px" },
    "sm":  { "$value": "13px" },
    "base":{ "$value": "14px", "$description": "Body default. Tool-density, not marketing-density." },
    "md":  { "$value": "16px" },
    "lg":  { "$value": "18px" },
    "xl":  { "$value": "20px" },
    "2xl": { "$value": "24px" },
    "3xl": { "$value": "30px" }
  },

  "fontWeight": {
    "$type": "fontWeight",
    "regular":  { "$value": 400 },
    "medium":   { "$value": 500 },
    "semibold": { "$value": 600, "$description": "Heaviest weight allowed. No 700+; it reads loud in a quiet tool." }
  },

  "lineHeight": {
    "$type": "number",
    "tight":  { "$value": 1.2 },
    "normal": { "$value": 1.5 }
  },

  "duration": {
    "$type": "duration",
    "fast": { "$value": "120ms" },
    "base": { "$value": "180ms" },
    "slow": { "$value": "240ms" }
  },

  "easing": {
    "$type": "cubicBezier",
    "standard": { "$value": [0.16, 1, 0.3, 1], "$description": "Expo-out. Fast start, gentle settle — the confident tool feel." }
  },

  "shadow": {
    "$type": "shadow",
    "$description": "Kept minimal. In dark mode, depth comes from surface lightness, not shadow — treat these as near-invisible there.",
    "sm": { "$value": { "color": "#0000000F", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" } },
    "md": { "$value": { "color": "#00000014", "offsetX": "0px", "offsetY": "2px", "blur": "8px", "spread": "0px" } }
  },

  "typography": {
    "$type": "typography",
    "$description": "Composite text styles. Bundle these instead of setting size/weight/line-height separately.",
    "title":      { "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.3xl}", "fontWeight": "{fontWeight.semibold}", "lineHeight": "{lineHeight.tight}" } },
    "heading":    { "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.xl}",  "fontWeight": "{fontWeight.semibold}", "lineHeight": "{lineHeight.tight}" } },
    "subheading": { "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.md}",  "fontWeight": "{fontWeight.medium}",   "lineHeight": "{lineHeight.normal}" } },
    "body":       { "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.base}","fontWeight": "{fontWeight.regular}",  "lineHeight": "{lineHeight.normal}" } },
    "label":      { "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.sm}",  "fontWeight": "{fontWeight.medium}",   "lineHeight": "{lineHeight.normal}" } },
    "code":       { "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "{fontSize.sm}",  "fontWeight": "{fontWeight.regular}",  "lineHeight": "{lineHeight.normal}" } },
    "caption":    { "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.xs}",  "fontWeight": "{fontWeight.regular}",  "lineHeight": "{lineHeight.normal}" } }
  },

  "semantic": {
    "color": {
      "$type": "color",
      "$description": "Role-based tokens — the layer UI actually consumes. $value = light mode. $extensions[\"com.tokens.mode\"].dark = dark mode. Same role name resolves to different primitives per theme; that is the whole point.",

      "bg": {
        "canvas":  { "$value": "{color.neutral.0}",   "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.950}" } }, "$description": "App background." },
        "surface": { "$value": "{color.neutral.50}",  "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.900}" } }, "$description": "Recessed panels, sidebars." },
        "raised":  { "$value": "{color.neutral.0}",   "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.800}" } }, "$description": "Cards, inputs, popovers." },
        "sunken":  { "$value": "{color.neutral.100}", "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.950}" } } }
      },
      "text": {
        "primary":   { "$value": "{color.neutral.900}", "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.100}" } } },
        "secondary": { "$value": "{color.neutral.600}", "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.400}" } } },
        "muted":     { "$value": "{color.neutral.500}", "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.500}" } }, "$description": "Placeholders, hints." },
        "onAccent":  { "$value": "{color.neutral.0}",   "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.950}" } }, "$description": "Text on an accent-filled surface." }
      },
      "border": {
        "default": { "$value": "{color.neutral.200}", "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.800}" } } },
        "strong":  { "$value": "{color.neutral.300}", "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.700}" } } }
      },
      "action": {
        "default": { "$value": "{color.indigo.500}", "$extensions": { "com.tokens.mode": { "dark": "{color.indigo.400}" } }, "$description": "Primary interactive color. One accent per view." },
        "hover":   { "$value": "{color.indigo.600}", "$extensions": { "com.tokens.mode": { "dark": "{color.indigo.500}" } } },
        "subtle":  { "$value": "{color.indigo.50}",  "$extensions": { "com.tokens.mode": { "dark": "{color.neutral.800}" } }, "$description": "Tinted background for selected/active states." }
      },
      "focus": {
        "ring": { "$value": "{color.indigo.500}", "$extensions": { "com.tokens.mode": { "dark": "{color.indigo.400}" } } }
      },
      "status": {
        "success": { "$value": "{color.green.500}", "$extensions": { "com.tokens.mode": { "dark": "{color.green.400}" } } },
        "warning": { "$value": "{color.amber.500}", "$extensions": { "com.tokens.mode": { "dark": "{color.amber.400}" } } },
        "error":   { "$value": "{color.red.500}",   "$extensions": { "com.tokens.mode": { "dark": "{color.red.400}" } } },
        "info":    { "$value": "{color.blue.500}",  "$extensions": { "com.tokens.mode": { "dark": "{color.blue.400}" } } }
      }
    }
  },

  "component": {
    "button": {
      "$description": "Every interactive component must define default / hover / focus / disabled. States below are expressed as separate tokens.",
      "primary": {
        "background":      { "$value": "{semantic.color.action.default}", "$type": "color" },
        "backgroundHover": { "$value": "{semantic.color.action.hover}",   "$type": "color" },
        "text":            { "$value": "{semantic.color.text.onAccent}",  "$type": "color" },
        "radius":          { "$value": "{radius.md}",  "$type": "dimension" },
        "paddingX":        { "$value": "{spacing.3}",  "$type": "dimension" },
        "paddingY":        { "$value": "{spacing.2}",  "$type": "dimension" }
      },
      "secondary": {
        "background": { "$value": "transparent",                  "$type": "color" },
        "border":     { "$value": "{semantic.color.border.strong}","$type": "color" },
        "text":       { "$value": "{semantic.color.text.primary}", "$type": "color" },
        "radius":     { "$value": "{radius.md}", "$type": "dimension" }
      }
    },
    "input": {
      "background":  { "$value": "{semantic.color.bg.raised}",     "$type": "color" },
      "border":      { "$value": "{semantic.color.border.default}","$type": "color" },
      "borderFocus": { "$value": "{semantic.color.focus.ring}",    "$type": "color" },
      "text":        { "$value": "{semantic.color.text.primary}",  "$type": "color" },
      "placeholder": { "$value": "{semantic.color.text.muted}",    "$type": "color" },
      "radius":      { "$value": "{radius.md}", "$type": "dimension" },
      "height":      { "$value": "36px",        "$type": "dimension" },
      "paddingX":    { "$value": "{spacing.3}", "$type": "dimension" }
    }
  }
}
